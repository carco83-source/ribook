# Dominio configurato - Caddy gestisce HTTPS automaticamente con Let's Encrypt
APP_SITE_ADDRESS=ribook.it, www.ribook.it
EXPO_PUBLIC_BACKEND_URL=https://ribook.it
DB_NAME=ribook

# Admin - Password per l'utente admin (creato automaticamente al primo avvio)
ADMIN_PASSWORD=CambiaMiInProduzione123!

# Stripe LIVE - Inserisci le tue chiavi da dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_YOUR_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_KEY_HERE
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_KEY_HERE
